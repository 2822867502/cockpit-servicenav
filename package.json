{
  "name": "cockpit-servicenav",
  "version": "1.0.0",
  "description": "Cockpit plugin for service navigation with quick access links to sub-services",
  "license": "GPL-3.0",
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ test/ --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src/ test/ --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/ coverage/ test-reports/"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@patternfly/react-core": "^5.4.0",
    "@patternfly/react-icons": "^5.4.0",
    "@patternfly/react-styles": "^5.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0",
    "uuid": "^10.0.0",
    "@types/uuid": "^10.0.0",
    "identity-obj-proxy": "^3.0.0"
  }
}
